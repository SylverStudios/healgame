{
  "name": "healgame",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts/content.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "content": "tsx scripts/content.ts",
    "check": "npm run typecheck && npm run lint && npm run test && vite build",
    "verify": "node scripts/verify.mjs",
    "verify:fast": "node scripts/verify.mjs --fast"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.9.0",
    "playwright": "^1.49.1",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
